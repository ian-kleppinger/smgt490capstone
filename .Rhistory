)
)
weightlifting$residuals <- weight_anova$residuals
weightlifting <- data.frame(
time = 1:66,
A = c(
2,1,1,1,2,2,1,2,1,2,1,
2,1,1,1,2,1,1,2,2,2,2,
1,1,1,1,1,1,1,1,2,1,2,
2,1,1,2,2,1,1,2,2,1,2,
2,1,2,1,1,2,1,1,2,2,2,
2,2,2,1,2,2,2,2,2,1,1
),
B = c(
2,1,3,1,2,3,3,2,2,2,1,
2,3,3,2,1,1,3,1,3,3,3,
3,1,1,2,1,2,2,3,3,2,1,
2,1,3,1,2,1,2,1,2,1,3,
2,1,3,2,2,1,3,2,1,1,1,
2,3,1,2,1,2,3,3,3,3,3
),
rate = c(
31,27,37,28,32,32,35,30,32,31,27,
34,33,34,31,26,25,35,24,33,31,36,
36,27,30,33,29,32,34,37,32,34,27,
31,27,38,27,30,29,34,25,34,28,34,
31,30,34,35,34,24,35,31,27,26,25,
32,35,24,33,23,30,34,32,33,37,38
)
)
weightlifting$A <- as.factor(weightlifting$A)
weightlifting$B <- as.factor(weightlifting$B)
weight_anova <- aov(rate ~ A + B + A*B, weightlifting)
weightlifting$residuals <- weight_anova$residuals
weight_anova
plot(weight_anova)
ggplot(weighlifting, mapping = aes(x = time, residuals, group = interaction(A, B))) +
geom_line(aes(color = coded_factor)) +
geom_point() +
labs(x = "Time Order", y = "Residuals", color = "Treatment")
ggplot(weighlifting, mapping = aes(x = time, residuals, group = interaction(A, B))) +
geom_line(aes(color = group)) +
geom_point() +
labs(x = "Time Order", y = "Residuals", color = "Treatment")
ggplot(weightlifting, mapping = aes(x = time, residuals, group = interaction(A, B))) +
geom_line(aes(color = group)) +
geom_point() +
labs(x = "Time Order", y = "Residuals", color = "Treatment")
ggplot(weightlifting, mapping = aes(x = time, residuals, group = interaction(A, B))) +
geom_line() +
geom_point() +
labs(x = "Time Order", y = "Residuals", color = "Treatment")
ggplot(weightlifting, mapping = aes(x = time, residuals, group = interaction(A, B))) +
geom_line(color = interaction(A, B)) +
geom_point() +
labs(x = "Time Order", y = "Residuals", color = "Treatment")
ggplot(weightlifting, mapping = aes(x = time, residuals, group = interaction(A, B))) +
geom_line(aes(color = interaction(A, B))) +
geom_point() +
labs(x = "Time Order", y = "Residuals", color = "Treatment")
